# Hermes VPS - environment variable template
# ============================================================
# Copy this file to .env on the VPS and fill in REAL values:
#   cp .env.example .env
#   chmod 600 .env
#   nano .env
#
# .env is gitignored. Real secrets MUST NOT be committed.
# ============================================================

# ---- Bridge-ingress (Telegram MTProto listener) -------------
# From https://my.telegram.org/apps
TG_API_ID=REPLACE_ME
TG_API_HASH=REPLACE_ME

# Generated via generate_session.py (run once locally)
TG_SESSION_STRING=REPLACE_ME

# Comma-separated chat IDs to monitor.
# Get IDs via list_dialogs.py
TG_MEME_CHAT_IDS=REPLACE_ME
TG_CONTRACT_CHAT_IDS=REPLACE_ME

# Optional: DC endpoint override (if default DC is unreachable from VPS)
# TG_DC_ID=5
# TG_SERVER_ADDRESS=91.108.56.130
# TG_SERVER_PORT=443

# Optional: SOCKS5 proxy for Telegram connection
# TG_PROXY_TYPE=socks5
# TG_PROXY_HOST=
# TG_PROXY_PORT=
# TG_PROXY_USERNAME=
# TG_PROXY_PASSWORD=

# Optional: enable legacy webhook endpoint (leave empty to disable)
# TELEGRAM_WEBHOOK_SECRET=

# ---- Shared paths -------------------------------------------
INBOX_PATH=/data/inbox
KEYWORDS_PATH=/blueprint/50-Intelligence/pipelines/keywords.yaml
LOG_LEVEL=info
LISTEN_PORT=8080

# ---- Watchdog -----------------------------------------------
# Separate Telegram bot for alerts (create via @BotFather)
ALERT_TELEGRAM_BOT_TOKEN=REPLACE_ME
ALERT_TELEGRAM_CHAT_ID=REPLACE_ME

# Bridge healthz URL (container DNS name within docker network)
BRIDGE_HEALTHZ_URL=http://hermes-bridge-ingress:8080/healthz
CHECK_INTERVAL_SECONDS=60
FAILURE_THRESHOLD=3

# ---- Cloudflare Tunnel --------------------------------------
# Create a tunnel at https://one.dash.cloudflare.com/
# Network -> Tunnels -> Create a tunnel
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME

# ---- Blueprint repository path (host mount) -----------------
BLUEPRINT_REPO_PATH=/opt/hermes-blueprint
