# Hermes VPS - environment variable template
# ============================================================
# Copy this file to .env on the VPS and fill in REAL values:
#   cp .env.example .env
#   chmod 600 .env
#   editor .env
#
# .env is gitignored. Real secrets MUST NOT be committed.
# Real values live in 90-Ops/secrets/hermes/ on each machine and
# are transferred to the VPS via SSH + age/sops, never via Syncthing.
# ============================================================

# ---- Image registry and tags --------------------------------
# Override only when you publish your own images. Defaults point
# to placeholder images that do not yet exist - replace before
# the first 'docker compose up'.
BRIDGE_IMAGE_REPO=wudgki/hermes-bridge
BRIDGE_IMAGE_TAG=v0.0.0-placeholder

INTEL_IMAGE_REPO=wudgki/hermes-intel
INTEL_IMAGE_TAG=v0.0.0-placeholder

WATCHDOG_IMAGE_REPO=wudgki/hermes-watchdog
WATCHDOG_IMAGE_TAG=v0.0.0-placeholder

# ---- Bridge ingress (Discord/Telegram/Feishu) ---------------
# Discord bot token. Create at https://discord.com/developers
DISCORD_TOKEN=REPLACE_ME

# Telegram bot token. Create via @BotFather
TELEGRAM_BOT_TOKEN=REPLACE_ME

# Feishu (Lark) webhook signature secret
FEISHU_WEBHOOK_SECRET=REPLACE_ME

# ---- Intel pipelines ----------------------------------------
# How often the worker wakes up to process the inbox (seconds).
INTEL_RUN_INTERVAL_SEC=3600

# Hour of day (UTC) at which the daily digest is generated.
INTEL_DAILY_HOUR_UTC=23

# ---- Watchdog -----------------------------------------------
WATCHDOG_INTERVAL_SEC=60

# Telegram bot used to PUSH alerts (can be the same as
# TELEGRAM_BOT_TOKEN above, or a separate alert-only bot).
ALERT_TELEGRAM_TOKEN=REPLACE_ME
ALERT_TELEGRAM_CHAT_ID=REPLACE_ME

# Optional: Feishu group webhook for alerts. Leave empty to
# disable Feishu alerts (Telegram alone is fine).
ALERT_FEISHU_WEBHOOK=

# Free disk space threshold in GB. Watchdog alerts when free
# space on the data volume drops below this.
DISK_FREE_THRESHOLD_GB=5

# ---- Cloudflare Tunnel --------------------------------------
# Create a tunnel at https://one.dash.cloudflare.com/
# Network -> Tunnels -> Create a tunnel
# Copy the connector token (long base64 string).
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME

# ---- Blueprint repository -----------------------------------
# Absolute path on the VPS host where the blueprint repo is
# git-cloned. The compose file mounts this read-only into
# intel-pipelines and bridge-ingress so they can read
# 50-Intelligence/pipelines/keywords.yaml.
BLUEPRINT_REPO_PATH=/opt/hermes/blueprint
